{
  "name": "novel-eval",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "description": "AI 驱动的中文网文写作与评估 monorepo",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "eval": "tsx packages/eval/src/index.ts evaluate",
    "compare": "tsx packages/eval/src/index.ts compare",
    "golden": "tsx packages/eval/src/index.ts golden",
    "write": "tsx packages/writer/src/index.ts write",
    "web": "tsx packages/web/server/index.ts",
    "web:dev": "pnpm --filter @novel-eval/web dev",
    "web:build": "pnpm --filter @novel-eval/web build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
