# Novel Eval 环境变量配置
#
# ⚠️ 本项目不自动读取 .env 文件。两种生效方式（任选其一）：
#   1. shell 直接 export（推荐）：
#        export ANTHROPIC_AUTH_TOKEN=你的key
#   2. 写进 ~/.claude/settings.json 的 env 字段（用 Claude Code 开发时方便）：
#        { "env": { "ANTHROPIC_AUTH_TOKEN": "你的key" } }
#
# 本文件仅作为"需要哪些变量"的备忘清单，本身不会被加载。
#
# 引擎在 packages/shared/config/engines.yml 里选（default: bigmodel）。
# 只需配置你实际使用的那个引擎的 key。

# ─── 智谱 GLM（默认引擎，推荐）──────────────────────────────────
# 在 https://open.bigmodel.cn 申请。两个变量名任填一个即可：
ANTHROPIC_AUTH_TOKEN=
# ZHIPUAI_API_KEY=          # 回退：上面那个没设置时用这个

# ─── DeepSeek（可选引擎）──────────────────────────────────────
# 在 https://platform.deepseek.com 申请。切换：把 engines.yml 的 default 改成 deepseek
# DEEPSEEK_API_KEY=

# ─── 服务端口与 Writer API（Web + CLI 共用）────────────────────
# Web 服务监听端口（默认 4000）
# PORT=4000
# CLI / Vite 代理访问的 Writer API 基址（优先于 PORT；默认 http://127.0.0.1:4000）
# WRITER_API_URL=http://127.0.0.1:4000
# Writer SQLite 数据库路径（Web 与 CLI 均需显式设置，禁止依赖 cwd）
# WRITER_DB_PATH=./data/writer/writer.db
